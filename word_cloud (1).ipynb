    "text = \"I love python python is easy and love coding\"\n",
    "\n",
    "wc = WordCloud(background_color=\"white\")\n",
    "wc.generate(text)\n",
    "\n",
    "plt.imshow(wc)\n",
    "plt.axis(\"off\")\n",
    "plt.show()"
   ]
